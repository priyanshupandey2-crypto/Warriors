# Application Environment
APP_ENV=development

# LangSmith Configuration
LANGSMITH_API_KEY=your-api-key
LANGSMITH_PROJECT=your_project_name
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Server Configuration
HOST=127.0.0.1
PORT=8000

# DATABASE INTEGRATION - Phase 4: PostgreSQL Configuration
# Format: postgresql://username:password@host:port/database_name
# IMPORTANT: Update these values based on your PostgreSQL setup
DATABASE_URL=postgresql://postgres:password@localhost:5432/auralearn_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=auralearn_db
