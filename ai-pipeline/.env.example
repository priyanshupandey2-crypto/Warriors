# ─── AI Pipeline Environment Variables ────────────────────────────────────────

# Google Gemini API key (required — primary LLM for stages 1, 2, 4)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral AI API key (optional — used for parallel stages 3a/3b)
# Falls back to Gemini if not set
# Get it at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Tavily search API key (required for web enrichment)
# Get it at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Redis connection URL (required for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Pipeline total timeout in milliseconds (default: 90000)
AI_PIPELINE_TIMEOUT_MS=300000

# Enable prompt audit logging (default: true)
# Set to false to disable prompt snapshot logging
PROMPT_AUDIT_ENABLED=true

# Log level (default: info)
LOG_LEVEL=info

# Node environment
NODE_ENV=development

# Use mock course data for testing (skip real AI generation)
# Set to true to return mock courses instantly
# Set to false to use real AI pipeline
USE_MOCK_DATA=false

# Directory containing organization documents for RAG layer (default: ./org_docs)
ORG_DOCS_DIR=./org_docs
