{
  "name": "auralearn-ai-pipeline",
  "version": "1.0.0",
  "description": "Production-grade AI course generation pipeline for AuraLearn",
  "main": "dist/ai/pipeline.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/ai/pipeline.ts",
    "start": "node dist/ai/pipeline.js",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "worker:prod": "node dist/worker.js",
    "server": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test-pipeline": "ts-node-dev --transpile-only src/test-pipeline.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@mistralai/mistralai": "^1.3.4",
    "@tavily/core": "^0.7.6",
    "bullmq": "^5.7.0",
    "dotenv": "^16.3.1",
    "groq-sdk": "^1.3.0",
    "ioredis": "^5.3.2",
    "pino": "^9.1.0",
    "tavily": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
