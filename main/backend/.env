# Application Environment
APP_ENV=development
DEBUG=true

# Server Configuration
HOST=127.0.0.1
PORT=8000

# LangSmith Configuration (Disabled for mock data)
LANGSMITH_API_KEY=optional
LANGSMITH_PROJECT=optional
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Database Configuration (For future database team)
DATABASE_URL=postgresql://user:password@localhost:5432/lxp_db

# Authentication (For future auth team)
JWT_SECRET=your-secret-key-here-min-32-chars-for-jwt-encoding
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
